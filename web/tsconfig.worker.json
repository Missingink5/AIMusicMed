{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["es2022"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["db/**/*.ts", "worker/**/*.ts"]
}
