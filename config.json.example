{
  "api_keys": {
    "deepseek_api_key": "YOUR_DEEPSEEK_API_KEY_HERE",
    "deepseek_base_url": "https://api.deepseek.com/v1"
  },
  "paths": {
    "base_dir": "/app/data",
    "cache_dir": "/app/cache",
    "temp_dir": "/app/temp"
  },
  "audio_settings": {
    "music_model": "facebook/musicgen-small",
    "tts_voice": "zh-CN-XiaoyiNeural",
    "speech_rate": "-25%",
    "speech_pitch": "-8Hz",
    "music_volume_reduction": 8,
    "output_bitrate": "128k",
    "enable_smart_voice_selection": true,
    "enable_ai_music": true,
    "use_preset_music": false,
    "use_high_quality_music": true,
    "music_quality_preference": "balanced"
  },
  "cleanup_settings": {
    "auto_cleanup_temp": true,
    "max_session_files": 3,
    "cleanup_older_than_days": 3,
    "force_d_drive_cache": false
  },
  "meditation_settings": {
    "default_duration_minutes": 3,
    "segment_duration_seconds": 20,
    "max_duration_minutes": 30,
    "min_duration_minutes": 1
  },
  "deployment": {
    "environment": "production",
    "log_level": "INFO",
    "debug": false,
    "cors_origins": ["*"],
    "max_workers": 4
  }
}
