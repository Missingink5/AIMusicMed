# Copy to deploy/.env and replace every CHANGE_ME value.
AIMUSICMED_DOMAIN=aimusicmed.cn
AIMUSICMED_ACME_EMAIL=admin@example.com

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIMUSICMED_FERNET_KEY=CHANGE_ME
# Generate with: openssl rand -hex 32
AIMUSICMED_WORKER_TOKEN=CHANGE_ME

AIMUSICMED_ADMIN_EMAIL=admin@example.com
# Production must remain false. Verification codes are delivered through Tencent Cloud SES API.
AIMUSICMED_DEV_AUTH_CODES=false
AIMUSICMED_SECURE_COOKIES=true
AIMUSICMED_PUBLIC_BASE_URL=https://aimusicmed.cn

# Tencent Cloud CAM sub-user credentials with SES-only permission.
# Keep these values only in deploy/.env on the server; never commit or paste them into logs.
TENCENTCLOUD_SECRET_ID=CHANGE_ME
TENCENTCLOUD_SECRET_KEY=CHANGE_ME
TENCENTCLOUD_REGION=ap-hongkong
AIMUSICMED_SES_FROM=AIMusicMed <no-reply@mail.aimusicmed.cn>
AIMUSICMED_SES_TEMPLATE_ID=208565
AIMUSICMED_SES_ALERT_TEMPLATE_ID=
AIMUSICMED_DISK_WARNING_PERCENT=70
AIMUSICMED_DISK_CLEANUP_PERCENT=80
AIMUSICMED_DISK_UPLOAD_STOP_PERCENT=85
AIMUSICMED_DISK_GENERATION_STOP_PERCENT=90
AIMUSICMED_DISK_RESUME_PERCENT=75

# The 2-core/2-GB production host must process only one generation task at a time.
AIMUSICMED_GLOBAL_TASK_CONCURRENCY=1

# Platform-paid provider credentials. ElevenLabs is optional.
DEEPSEEK_API_KEY=CHANGE_ME
MINIMAX_API_KEY=CHANGE_ME
ELEVENLABS_API_KEY=

# Encrypts backup archives independently from BYOK encryption.
# Generate with: openssl rand -base64 48
AIMUSICMED_BACKUP_PASSPHRASE=CHANGE_ME
AIMUSICMED_BACKUP_KEEP_DAILY=7
AIMUSICMED_BACKUP_KEEP_WEEKLY=4
AIMUSICMED_BACKUP_KEEP_MONTHLY=3
AIMUSICMED_BACKUP_MAX_REPO_MB=12288
AIMUSICMED_BACKUP_MIN_FREE_MB=6144
