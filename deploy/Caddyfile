{
	email {$AIMUSICMED_ACME_EMAIL}
}

{$AIMUSICMED_DOMAIN} {
	encode zstd gzip {
		skip_encoding audio/mpeg audio/wav audio/mp3
		skip_encoding image/png image/jpeg image/webp image/svg+xml image/gif
		skip_encoding application/javascript text/css font/woff font/woff2
		skip_encoding application/octet-stream
	}

	# Worker endpoints stay reachable only on Docker's private api:8000 network.
	handle /api/v1/internal/* {
		respond 404
	}

	handle_path /api/v1/* {
		reverse_proxy api:8000
	}

	handle {
		reverse_proxy web:3000
	}

	# Cache hashed static assets aggressively (vinext filenames include content hash).
	@staticAssets {
		path /assets/* /favicon.ico /manifest.webmanifest /sw.js /og.png
	}
	header @staticAssets Cache-Control "public, max-age=31536000, immutable"

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), geolocation=(), microphone=(self)"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self'; media-src 'self' blob:; font-src 'self'"
		-Server
	}

	log {
		output stdout
		format console
	}
}

www.{$AIMUSICMED_DOMAIN} {
	route {
		header -Server
		redir https://{$AIMUSICMED_DOMAIN}{uri} permanent
	}
}
