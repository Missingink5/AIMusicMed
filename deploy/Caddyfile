{
	email {$AIMUSICMED_ACME_EMAIL}

	servers :443 {
		protocols h1
	}
}

{$AIMUSICMED_DOMAIN} {
	encode zstd gzip

	# Worker endpoints stay reachable only on Docker's private api:8000 network.
	handle /api/v1/internal/* {
		respond 404
	}

	handle_path /api/v1/* {
		reverse_proxy api:8000
	}

	handle {
		reverse_proxy web:3000
	}

	# API responses must never be cached — except audio streaming
	# which sets its own Cache-Control from the backend.
	@apiResponses {
		path /api/*
		not path /api/v1/works/*/audio
	}
	header @apiResponses Cache-Control "no-store"

	# Static assets with content-hash filenames can be cached aggressively.
	@staticAssets {
		path /assets/*
	}
	header @staticAssets Cache-Control "public, max-age=31536000, immutable"

	# Service worker must never be cached — stale SW breaks the site.
	@swFile {
		path /sw.js
	}
	header @swFile Cache-Control "no-store"

	# Manifest may be revalidated but not cached indefinitely.
	@manifestFile {
		path /manifest.webmanifest
	}
	header @manifestFile Cache-Control "no-cache"

	# Non-API HTML pages should be revalidated on every navigation.
	@htmlPages {
		not path /api/* /assets/* /favicon.ico /og.png /sw.js /manifest.webmanifest
	}
	header @htmlPages Cache-Control "no-cache, must-revalidate"

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), geolocation=(), microphone=(self)"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self'; media-src 'self' blob:; font-src 'self' data:; manifest-src 'self'; worker-src 'self' blob:"
		-Server
	}

	log {
		output stdout
		format console
	}
}

www.{$AIMUSICMED_DOMAIN} {
	route {
		header -Server
		redir https://{$AIMUSICMED_DOMAIN}{uri} permanent
	}
}
