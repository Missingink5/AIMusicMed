# Generate once with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIMUSICMED_FERNET_KEY=PUT_A_FERNET_KEY_HERE
AIMUSICMED_WORKER_TOKEN=PUT_AT_LEAST_24_RANDOM_CHARACTERS_HERE
AIMUSICMED_ADMIN_EMAIL=admin@example.com

AIMUSICMED_WEB_DATA=webapp-data
AIMUSICMED_DB_PATH=webapp-data/app.db
AIMUSICMED_STORAGE_ROOT=webapp-data/storage
AIMUSICMED_GLOBAL_TASK_CONCURRENCY=1
# For local-only development, temporarily set these to true / false.
AIMUSICMED_DEV_AUTH_CODES=false
AIMUSICMED_SECURE_COOKIES=true

# Production Tencent Cloud SES API (dev mode returns verification codes instead).
AIMUSICMED_PUBLIC_BASE_URL=https://aimusicmed.cn
TENCENTCLOUD_SECRET_ID=PUT_CAM_SUBUSER_SECRET_ID_HERE
TENCENTCLOUD_SECRET_KEY=PUT_CAM_SUBUSER_SECRET_KEY_HERE
TENCENTCLOUD_REGION=ap-hongkong
AIMUSICMED_SES_FROM=AIMusicMed <no-reply@mail.aimusicmed.cn>
# Create and approve this template in Tencent Cloud SES with action, code, and expires variables.
AIMUSICMED_SES_TEMPLATE_ID=208565
AIMUSICMED_SES_ALERT_TEMPLATE_ID=
AIMUSICMED_DISK_WARNING_PERCENT=70
AIMUSICMED_DISK_CLEANUP_PERCENT=80
AIMUSICMED_DISK_UPLOAD_STOP_PERCENT=85
AIMUSICMED_DISK_GENERATION_STOP_PERCENT=90
AIMUSICMED_DISK_RESUME_PERCENT=75
